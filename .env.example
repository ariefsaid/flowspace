# --- Supabase (local stack via `supabase start`) ---
# App DB connection. drizzle uses this; the server connects privileged.
# Local Supabase CLI ports (match supabase/config.toml).
DATABASE_URL="postgresql://postgres:postgres@localhost:64322/postgres"
# Throwaway DB for integration tests (the same local stack DB; tests truncate between runs).
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:64322/postgres"

NEXT_PUBLIC_SUPABASE_URL="http://localhost:64321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="REPLACE_WITH_LOCAL_ANON_KEY"   # from `supabase status` output
SUPABASE_SERVICE_ROLE_KEY="REPLACE_WITH_LOCAL_SERVICE_ROLE_KEY"  # server-only, NEVER NEXT_PUBLIC

# White-label branding
NEXT_PUBLIC_BRAND_NAME="FlowSpace"

# Seed (dev-only fallbacks; set real values in your local .env, never commit)
SEED_ORG_SLUG="flowspace"
SEED_ADMIN_EMAIL="admin@flowspace.test"
SEED_ADMIN_PASSWORD="dev-admin-pw"
SEED_MEMBER_EMAIL="budi@flowspace.test"
SEED_MEMBER_PASSWORD="dev-member-pw"
SEED_BARISTA_EMAIL="barista@flowspace.test"
SEED_BARISTA_PASSWORD="dev-barista-pw"
