# Neon-style Postgres. Pooled connection for the app, direct for migrations.
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/flowspace?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-example.region.aws.neon.tech/flowspace?sslmode=require"

# Auth.js (NextAuth v5)
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# White-label branding
NEXT_PUBLIC_BRAND_NAME="FlowSpace"
